<file path="database/setup.sql">
-- ══════════════════════════════════════════════════════════
--  FARMACY — Setup inicial de PostgreSQL
--
--  PASO 1: psql -U postgres  →  \i database/setup.sql
--  PASO 2: Prisma genera el schema y lo aplica
-- ══════════════════════════════════════════════════════════

-- 1. Usuario y base de datos
CREATE USER farmacy_user WITH PASSWORD 'farmacy_pass';

CREATE DATABASE farmacy_db
  OWNER     = farmacy_user
  ENCODING  = 'UTF8'
  LC_COLLATE = 'es_CO.UTF-8'
  LC_CTYPE   = 'es_CO.UTF-8'
  TEMPLATE  = template0;
-- Si el locale es_CO no está disponible usa en_US.UTF-8

GRANT ALL PRIVILEGES ON DATABASE farmacy_db TO farmacy_user;

-- ──────────────────────────────────────────────────────────
-- Conéctate ahora: \c farmacy_db farmacy_user
-- ──────────────────────────────────────────────────────────

-- 2. Extensiones
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";
CREATE EXTENSION IF NOT EXISTS "pgcrypto";

-- 3. Enum de rol (Prisma lo crea, pero aquí como referencia)
-- CREATE TYPE "RolEmpleado" AS ENUM ('ADMINISTRADOR', 'FARMACEUTA', 'AUXILIAR');

-- ══════════════════════════════════════════════════════════
--  IMPORTANTE: Las tablas las crea Prisma con:
--
--    cd backend
--    npm run db:generate   ← genera el cliente TypeScript
--    npm run db:push       ← aplica schema.prisma a la BD
--    npm run db:seed       ← inserta datos iniciales
--
--  Flujo completo de desarrollo:
--
--  1. docker-compose -f docker-compose.dev.yml up -d
--       (levanta PostgreSQL en localhost:5432 y Redis en 6379)
--
--  2. cp .env.example .env
--       (rellena DATABASE_URL y los secrets JWT)
--
--  3. cd backend && npm install
--  4. npm run db:generate
--  5. npm run db:push
--  6. npm run db:seed
--
--  7. npm run dev             ← backend en localhost:3001
--  8. cd ../frontend && npm install && npm run dev
--       ← tienda en localhost:5173
-- ══════════════════════════════════════════════════════════

-- 4. Verificar que todo esté bien:
SELECT current_database(), current_user, version();
</file>

<file path="docker-compose.dev.yml">
version: '3.9'

# ══════════════════════════════════════════════════════════
#  FARMACY — Docker Compose DESARROLLO LOCAL
#
#  Solo levanta la base de datos y Redis.
#  El backend y frontend corren con npm run dev en tu máquina.
#
#  Uso:
#    docker-compose -f docker-compose.dev.yml up -d
#    docker-compose -f docker-compose.dev.yml down
#    docker-compose -f docker-compose.dev.yml logs -f
# ══════════════════════════════════════════════════════════

services:

  # ── PostgreSQL 15 ──────────────────────────────────────
  postgres:
    image: postgres:15-alpine
    container_name: farmacy_postgres_dev
    restart: unless-stopped
    environment:
      POSTGRES_DB: farmacy_db
      POSTGRES_USER: farmacy_user
      POSTGRES_PASSWORD: farmacy_pass
      TZ: America/Bogota
    ports:
      - "5432:5432"            # Accesible desde tu máquina en localhost:5432
    volumes:
      - farmacy_pg_data:/var/lib/postgresql/data
      - ./database/init:/docker-entrypoint-initdb.d  # Scripts SQL al iniciar
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U farmacy_user -d farmacy_db"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ── Redis ──────────────────────────────────────────────
  redis:
    image: redis:7-alpine
    container_name: farmacy_redis_dev
    restart: unless-stopped
    ports:
      - "6379:6379"
    volumes:
      - farmacy_redis_data:/data
    command: redis-server --appendonly yes
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ── pgAdmin (Interfaz visual para PostgreSQL) ──────────
  # Accede en: http://localhost:5050
  # Email: admin@farmacy.co  /  Contraseña: admin
  pgadmin:
    image: dpage/pgadmin4:latest
    container_name: farmacy_pgadmin
    restart: unless-stopped
    environment:
      PGADMIN_DEFAULT_EMAIL: admin@farmacy.co
      PGADMIN_DEFAULT_PASSWORD: admin
      PGADMIN_CONFIG_SERVER_MODE: 'False'
    ports:
      - "5050:80"
    volumes:
      - farmacy_pgadmin_data:/var/lib/pgadmin
    depends_on:
      postgres:
        condition: service_healthy

volumes:
  farmacy_pg_data:
    name: farmacy_pg_data_dev
  farmacy_redis_data:
    name: farmacy_redis_data_dev
  farmacy_pgadmin_data:
    name: farmacy_pgadmin_data_dev

networks:
  default:
    name: farmacy_dev_network
</file>

<file path="docker-compose.yml">
version: '3.9'

# ══════════════════════════════════════════════════════════
#  FARMACY — Docker Compose PRODUCCIÓN
#  Levanta toda la aplicación: backend, frontend, BD, Redis
#
#  Uso:
#    docker-compose up -d --build
#    docker-compose down
#    docker-compose logs -f backend
# ══════════════════════════════════════════════════════════

services:

  postgres:
    image: postgres:15-alpine
    container_name: farmacy_postgres
    restart: always
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-farmacy_db}
      POSTGRES_USER: ${POSTGRES_USER:-farmacy_user}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      TZ: America/Bogota
    volumes:
      - farmacy_pg_data:/var/lib/postgresql/data
    networks:
      - farmacy_network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-farmacy_user}"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    container_name: farmacy_redis
    restart: always
    volumes:
      - farmacy_redis_data:/data
    command: redis-server --appendonly yes --requirepass ${REDIS_PASSWORD}
    networks:
      - farmacy_network

  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: farmacy_backend
    restart: always
    env_file: .env
    environment:
      DATABASE_URL: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
      REDIS_URL: redis://:${REDIS_PASSWORD}@redis:6379
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - farmacy_network
    ports:
      - "3000:3000"

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
      args:
        VITE_API_URL: ${VITE_API_URL}
        VITE_APP_NAME: ${VITE_APP_NAME}
    container_name: farmacy_frontend
    restart: always
    networks:
      - farmacy_network
    ports:
      - "80:80"
    depends_on:
      - backend

volumes:
  farmacy_pg_data:
  farmacy_redis_data:

networks:
  farmacy_network:
    name: farmacy_prod_network
</file>

