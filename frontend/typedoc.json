{
  "$schema": "https://typedoc.org/schema.json",
  "name": "Farmacy Frontend",
  "entryPointStrategy": "expand",
  "entryPoints": [
    "./src/components",
    "./src/hooks",
    "./src/store",
    "./src/services",
    "./src/types",
    "./src/config",
    "./src/utils",
    "./src/data"
  ],
  "out": "./docs/api",
  "tsconfig": "./tsconfig.json",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeExternals": true,
  "excludeInternal": true,
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "notDocumented": false
  },
  "categorizeByGroup": true,
  "defaultCategory": "Otros",
  "categoryOrder": [
    "Componentes",
    "Layouts",
    "Hooks",
    "Stores",
    "Servicios",
    "Tipos",
    "Configuración",
    "Utilidades",
    "Datos",
    "PWA",
    "Push",
    "Chatbot",
    "Real-time",
    "Autenticación",
    "Carrito",
    "Catálogo",
    "Pagos",
    "Pedidos",
    "*"
  ],
  "searchInComments": true,
  "cleanOutputDir": true,
  "plugin": [],
  "readme": "./docs/README.md",
  "gitRevision": "main",
  "sourceLinkTemplate": "https://github.com/andyhp2025/farmacy/blob/main/{path}#L{line}"
}
