{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/app.tsx",
    "src/main.tsx",
    "src/config/api.ts",
    "src/config/constants.ts",
    "src/store/authStore.ts",
    "src/store/carritoStore.ts",
    "src/store/uiStore.ts",
    "src/types/producto.types.ts",
    "src/hooks/index.ts",
    "src/hooks/useScanner.ts",
    "src/services/index.ts",
    "src/utils/fuzzySearch.ts"
  ],
  "out": "docs/api/frontend",
  "name": "Farmacy Frontend",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeExternals": true,
  "disableSources": true,
  "theme": "default",
  "plugin": []
}
