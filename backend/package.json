{
  "name": "farmacy-backend",
  "version": "1.0.0",
  "description": "Farmacy SGF — Backend API",
  "main": "dist/server.js",
  "scripts": {
    "predev": "prisma generate --schema=../database/prisma/schema.prisma && node scripts/prisma-postgenerate.js",
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "db:generate": "npx prisma generate --schema=../database/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=../database/prisma/schema.prisma",
    "db:push": "npx prisma db push --schema=../database/prisma/schema.prisma",
    "db:seed": "npx ts-node ../database/seeds/seed.ts",
    "db:studio": "npx prisma studio --schema=../database/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@types/compression": "^1.8.1",
    "@types/express": "4.17.21",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.4",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.0.6",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.8",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "stripe": "^14.10.0",
    "web-push": "^3.6.7",
    "winston": "^3.11.0",
    "ws": "^8.21.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
